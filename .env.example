# ------------------------------------------------------------------
# Ceverse — Supabase + app configuration
# Copy to .env and fill from your Supabase project dashboard.
# ------------------------------------------------------------------

NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Supabase (Project Settings → API) -----------------------------
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Service role — server only (seed, admin). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Database (Project Settings → Database → Connection string) ----
# Use "Transaction" pooler for DATABASE_URL (port 6543) and
# "Session" or direct for DIRECT_URL / migrations (port 5432).
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# --- Redis (optional locally) --------------------------------------
REDIS_URL="redis://localhost:6379"

# --- Stripe Connect (optional) -------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- S3-compatible storage (optional) ------------------------------
S3_ENDPOINT=""
S3_REGION="us-east-1"
S3_BUCKET="ceverse-uploads"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# --- Email (optional; Supabase can also send auth emails) ----------
RESEND_API_KEY=""
EMAIL_FROM="Ceverse <no-reply@ceverse.com>"

LOG_LEVEL="info"
