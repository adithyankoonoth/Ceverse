# ------------------------------------------------------------------
# Ceverse environment template — copy to .env and fill in real values.
# Every variable is validated at boot by src/lib/env.ts; the app will
# refuse to start with missing or malformed configuration.
# ------------------------------------------------------------------

# --- Core ---------------------------------------------------------
NODE_ENV="development"
# Public origin of the app (no trailing slash). Used for auth callbacks,
# email links, and open-redirect validation.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Database (Neon PostgreSQL) ------------------------------------
# Pooled connection string for the app.
DATABASE_URL="postgresql://user:password@localhost:5432/ceverse?schema=public"
# Direct (non-pooled) connection for Prisma migrations.
DIRECT_URL="postgresql://user:password@localhost:5432/ceverse?schema=public"

# --- Redis (cache, rate limiting, BullMQ, realtime pub/sub) --------
REDIS_URL="redis://localhost:6379"

# --- Auth (Better Auth) ---------------------------------------------
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# --- Stripe Connect --------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- S3-compatible object storage ------------------------------------
S3_ENDPOINT="https://s3.us-east-1.amazonaws.com"
S3_REGION="us-east-1"
S3_BUCKET="ceverse-uploads"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# --- Email (Resend) ---------------------------------------------------
RESEND_API_KEY=""
EMAIL_FROM="Ceverse <no-reply@ceverse.com>"

# --- Observability / misc ---------------------------------------------
LOG_LEVEL="info"
